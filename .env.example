# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Microsoft SQL Server ─────────────────────────────────────────────────────
# SQL Express default instance:
DB_SERVER=LOCALHOST\SQLEXPRESS
DB_PORT=1433
DB_NAME=RentLux
DB_USER=sa
DB_PASSWORD=YourStrongPassword123!
DB_ENCRYPT=true
DB_WINDOWS_AUTH=false

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=rentlux_super_secret_jwt_key_2024_change_in_production
JWT_EXPIRES_IN=7d

# ── Groq AI (free at https://console.groq.com) ───────────────────────────────
# Used for: AI chat assistant + rental agreement generation
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Email / SMTP (optional — used for password reset) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
