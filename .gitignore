# ──────────────────────────────────────────────
#  RentLux — .gitignore
# ──────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/
.npm/

# ── Environment & Secrets ─────────────────────
.env
.env.*
!.env.example

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock

# ── Runtime / Build ───────────────────────────
dist/
build/
.cache/
.parcel-cache/
coverage/

# ── Database files ────────────────────────────
database/*.mdf
database/*.ldf
database/*.bak
*.sqlite
*.sqlite3
*.db

# ── Downloaded / Generated assets ────────────
# Prevent locally downloaded images from being committed
frontend/images/downloaded/
downloads/

# ── OS files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Temporary files ───────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
